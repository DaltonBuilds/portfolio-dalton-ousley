# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# IDEs
.kiro
.vscode

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# Cloudflare
wrangler.toml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# velite generated files
.velite

# Terraform
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/terraform.tfstate.*.backup
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
terraform/!terraform.tfvars.example
terraform/backend.hcl
terraform/tfplan
terraform/*.tfplan
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# Sensitive files - never commit
**/secrets.txt
**/*-backup.txt
**/credentials.json
**/*.pem
**/*.key
