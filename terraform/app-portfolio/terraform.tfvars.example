# Copy this file to terraform.tfvars and fill in your values.

# ============================================================================
# Required
# ============================================================================

owner_email             = "your-email@example.com"
notification_email      = "your-email@example.com"
notification_from_email = "your-email@example.com"

# ============================================================================
# AWS
# ============================================================================

aws_profile = "your-sso-profile"
aws_region  = "us-east-1"

# ============================================================================
# Optional (defaults are production-ready)
# ============================================================================

# environment  = "prod"
# project_name = "portfolio-leads"

# allowed_origins = [
#   "https://example.com",
#   "https://www.example.com",
#   "http://localhost:3000",
# ]

# dynamodb_ttl_days         = 548
# lambda_memory_size        = 256
# lambda_timeout            = 10
# lambda_log_retention_days = 30
# api_throttle_burst_limit  = 10
# api_throttle_rate_limit   = 5

# ============================================================================
# Secrets
# Secret values are managed outside Terraform to keep them out of state.
# Run ./scripts/populate-secrets.sh after apply to populate values.
# ============================================================================
